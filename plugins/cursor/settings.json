{
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.fontWeightBold": "bold",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.shell.osx": "/opt/homebrew/bin/zsh",
  "terminal.integrated.env.osx": {
    "TERM_PROGRAM": "cursor"
  },
  "terminal.integrated.allowChords": false,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.rightClickBehavior": "default",
  "terminal.integrated.copyOnSelection": false,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.tabs.showActions": "singleTerminal",
  "terminal.integrated.tabs.hideCondition": "never",
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.unicodeVersion": "11",
  "terminal.integrated.minimumContrastRatio": 4.5,
  "terminal.integrated.drawBoldTextInBrightColors": true,
  "terminal.integrated.fastScrollSensitivity": 5,
  "terminal.integrated.mouseWheelScrollSensitivity": 1,
  "terminal.integrated.bellDuration": 1000,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "/opt/homebrew/bin/zsh",
      "args": [
        "-l"
      ],
      "env": {
        "TERM_PROGRAM": "cursor"
      }
    }
  },
  "editor.fontFamily": "MesloLGS NF, 'Courier New', monospace",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.5,
  "editor.fontLigatures": true,
  "editor.renderWhitespace": "selection",
  "editor.rulers": [
    80,
    120
  ],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.trimAutoWhitespace": true,
  "editor.formatOnSave": false,
  "editor.formatOnPaste": true,
  "editor.formatOnType": false,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "editor.minimap.enabled": true,
  "editor.minimap.side": "right",
  "editor.minimap.showSlider": "mouseover",
  "editor.wordWrap": "off",
  "editor.wrappingIndent": "none",
  "editor.cursorBlinking": "blink",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.mouseWheelZoom": true,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.snippetSuggestions": "top",
  "editor.suggest.insertMode": "insert",
  "editor.suggest.filterGraceful": true,
  "editor.suggest.localityBonus": true,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.tabCompletion": "on",
  "editor.parameterHints.enabled": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },
  "editor.suggestSelection": "first",
  "editor.wordBasedSuggestions": "matchingDocuments",
  "editor.semanticHighlighting.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.highlightActiveIndentation": true,
  "editor.guides.indentation": true,
  "editor.linkedEditing": true,
  "editor.occurrencesHighlight": "singleFile",
  "editor.selectionHighlight": true,
  "editor.wordHighlightBackground": "#575757",
  "editor.wordHighlightStrongBackground": "#004972",
  "editor.find.addExtraSpaceOnTop": false,
  "editor.find.autoFindInSelection": "never",
  "editor.find.seedSearchStringFromSelection": "always",
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 10,
  "workbench.editor.limit.perEditorGroup": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.tabCloseButton": "right",
  "workbench.editor.tabSizing": "fit",
  "workbench.editor.wrapTabs": false,
  "workbench.startupEditor": "newUntitledFile",
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.iconTheme": "vs-seti",
  "workbench.tree.indent": 20,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.activityBar.location": "default",
  "workbench.sideBar.location": "left",
  "workbench.panel.defaultLocation": "bottom",
  "workbench.panel.opensMaximized": "never",
  "workbench.statusBar.visible": true,
  "workbench.tabs.wrapTabs": false,
  "workbench.commandPalette.history": 50,
  "workbench.quickOpen.closeOnFocusLost": true,
  "workbench.settings.editor": "ui",
  "workbench.settings.openDefaultSettings": false,
  "workbench.settings.useSplitJSON": false,
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "files.associations": {
    "*.conf": "properties",
    "*.env": "properties",
    "Dockerfile*": "dockerfile",
    "*.dockerfile": "dockerfile",
    "*.zshrc": "shellscript",
    "*.bashrc": "shellscript",
    "*.zsh": "shellscript",
    "*.bash": "shellscript"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.nyc_output": true,
    "**/coverage": true,
    "**/.coverage": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "**/.vscode": false
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.hg/store/**": true,
    "**/__pycache__/**": true,
    "**/.coverage": true,
    "**/coverage/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/.git": true,
    "**/.DS_Store": true,
    "**/coverage": true,
    "**/.nyc_output": true,
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "search.followSymlinks": false,
  "search.smartCase": false,
  "search.useGlobalIgnoreFiles": true,
  "search.useIgnoreFiles": true,
  "search.useParentIgnoreFiles": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.openEditors.visible": 0,
  "explorer.autoReveal": true,
  "explorer.compactFolders": false,
  "explorer.decorations.badges": true,
  "explorer.decorations.colors": true,
  "explorer.sortOrder": "type",
  "explorer.sortOrderLexicographicOptions": "default",
  "scm.inputFontFamily": "MesloLGS NF",
  "debug.console.fontFamily": "MesloLGS NF",
  "debug.console.fontSize": 14,
  "markdown.preview.fontFamily": "MesloLGS NF, -apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif",
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.autofetchPeriod": 180,
  "git.decorations.enabled": true,
  "git.enableStatusBarSync": true,
  "git.showPushSuccessNotification": true,
  "git.suggestSmartCommit": true,
  "extensions.autoCheckUpdates": true,
  "extensions.autoUpdate": true,
  "extensions.ignoreRecommendations": true,
  "extensions.showRecommendationsOnlyOnDemand": false,
  "telemetry.telemetryLevel": "off",
  "update.showReleaseNotes": true,
  "security.workspace.trust.untrustedFiles": "open",
  "security.workspace.trust.banner": "never",
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.emptyWindow": false,
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "on",
  "breadcrumbs.symbolPath": "on",
  "breadcrumbs.symbolSortOrder": "position",
  "problems.decorations.enabled": true,
  "problems.showCurrentInStatus": true,
  "zenMode.centerLayout": true,
  "zenMode.fullScreen": false,
  "zenMode.hideActivityBar": true,
  "zenMode.hideLineNumbers": false,
  "zenMode.hideStatusBar": true,
  "zenMode.restore": true,
  "zenMode.silentNotifications": true,
  "window.zoomLevel": 0,
  "window.newWindowDimensions": "inherit",
  "window.openFilesInNewWindow": "off",
  "window.openFoldersInNewWindow": "default",
  "window.restoreFullscreen": false,
  "window.restoreWindows": "all",
  "window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator}${appName}",
  "window.titleBarStyle": "native",
  "window.clickThroughInactive": true,
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.renderSideBySide": true,
  "diffEditor.wordWrap": "off",
  "merge-conflict.autoNavigateNextConflict.enabled": true,
  "outline.collapseItems": "alwaysCollapse",
  "outline.icons": true,
  "outline.problems.enabled": true,
  "outline.problems.badges": true,
  "outline.problems.colors": true,
  "timeline.excludeSources": [],
  "timeline.pageOnScroll": false,
  "timeline.pageSize": 20,
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "notebook.compactView": true,
  "notebook.insertToolbarLocation": "betweenCells",
  "notebook.showCellStatusBar": "visible",
  "notebook.showFoldingControls": "mouseover",
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },
  "emmet.triggerExpansionOnTab": true,
  "html.format.indentInnerHtml": true,
  "html.format.wrapLineLength": 120,
  "css.validate": true,
  "less.validate": true,
  "scss.validate": true,
  "javascript.format.semicolons": "insert",
  "javascript.preferences.quoteStyle": "single",
  "javascript.suggest.autoImports": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.format.semicolons": "insert",
  "typescript.preferences.quoteStyle": "single",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "json.format.keepLines": false,
  "json.schemas": [],
  "yaml.format.enable": true,
  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,
  "python.defaultInterpreterPath": "/usr/bin/python3",
  "python.formatting.provider": "black",
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": true,
  "python.linting.lintOnSave": true,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "go.formatTool": "goimports",
  "go.lintTool": "golint",
  "go.vetOnSave": "package",
  "go.buildOnSave": "package",
  "go.lintOnSave": "package",
  "go.coverOnSave": false,
  "go.useCodeSnippetsOnFunctionSuggest": true,
  "go.inferGopath": true,
  "rust-analyzer.checkOnSave.command": "clippy",
  "rust-analyzer.cargo.allFeatures": true,
  "rust-analyzer.procMacro.enable": true,
  "shellcheck.enable": true,
  "shellcheck.executablePath": "/opt/homebrew/bin/shellcheck",
  "shellcheck.run": "onSave",
  "docker.showStartPage": false,
  "remote.SSH.remotePlatform": {},
  "remote.SSH.showLoginTerminal": true,
  "remote.SSH.configFile": "~/.ssh/config",
  "cursor.chat.alwaysNewSession": false,
  "cursor.general.enableTooltips": true,
  "cursor.cpp.disabledLanguages": [],
  "aichat.autoScroll": true,
  "workbench.editor.tabActionLocation": "right",
  "zenMode.showTabs": "single",
  "cursor.composer.shouldAutoScrollToBottom": false,
  "cursor.composer.shouldAllowCustomModes": true,
  "git.openRepositoryInParentFolders": "never",
  "cursor.rpcFileLogger.enabled": true,
  "update.releaseTrack": "dev",
  "update.mode": "silentlyApplyOnQuit",
  "window.commandCenter": true,
  "workbench.experimental.share.enabled": true,
  "claudeCode.allowDangerouslySkipPermissions": true,
  "claudeCode.preferredLocation": "panel",
  "claudeCode.environmentVariables": [],
  "claudeCode.selectedModel": "opus",
  "editor.accessibilitySupport": "on"
}
