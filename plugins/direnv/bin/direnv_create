#!/bin/bash

set -euo pipefail

# Constants
readonly SCRIPT_NAME="$(basename "$0")"
readonly SUPPORTED_TYPES="envrc, python"

# Get default Python version
get_python_default_version() {
    python3 --version 2>/dev/null | awk '{print $2}' || echo "3"
}

readonly PYTHON_DEFAULT_VERSION=$(get_python_default_version)

# Function to deploy .envrc file
deploy_envrc() {
    local envrc_source="${DOTFILES_DIR}/plugins/direnv/.envrc"
    local envrc_target=".envrc"

    if [[ -z "${DOTFILES_DIR:-}" ]]; then
        echo "Error: DOTFILES_DIR environment variable is not set" >&2
        exit 1
    fi

    if [[ ! -f "$envrc_source" ]]; then
        echo "Error: Source .envrc file not found at $envrc_source" >&2
        exit 1
    fi

    if [[ -e "$envrc_target" ]]; then
        echo "Warning: .envrc already exists, removing it first" >&2
        rm -f "$envrc_target"
    fi

    ln -s "$envrc_source" "$envrc_target"
    echo ".envrc deployed successfully"
}

# Function to create a Python virtual environment
create_python_env() {
    local version="${1:-}"

    if [[ -d ".venv" ]]; then
        echo "Warning: .venv directory already exists, removing it first" >&2
        rm -rf ".venv"
    fi

    echo "Creating Python virtual environment..."

    if [[ -n "$version" ]]; then
        if command -v mise >/dev/null 2>&1; then
            echo "Using Python ${version} via mise"
            mise exec "python@${version}" -- python3 -m venv .venv
        else
            local version_cmd="python${version}"
            if command -v "$version_cmd" >/dev/null 2>&1; then
                echo "Using ${version_cmd}"
                "$version_cmd" -m venv .venv
            else
                echo "Error: ${version_cmd} not found in PATH and mise is not installed" >&2
                exit 1
            fi
        fi
    else
        echo "Using default Python version: $PYTHON_DEFAULT_VERSION"
        python3 -m venv .venv
    fi

    deploy_envrc
    echo "Python virtual environment created successfully"
}

# Function to display usage information
show_usage() {
    cat << EOF
Usage: $SCRIPT_NAME <type> [version]

Set up direnv integration for the current directory.

Types:
  envrc         Deploy .envrc only (auto-loads .env files)
  python, py    Create a Python virtual environment + .envrc [version]

Options:
  version       Python version to use (only for python type)
                Default: $PYTHON_DEFAULT_VERSION

Examples:
  $SCRIPT_NAME envrc            # Just deploy .envrc (Go, Terraform, Rust, etc.)
  $SCRIPT_NAME python           # Use default Python ($PYTHON_DEFAULT_VERSION)
  $SCRIPT_NAME python 3.11      # Use Python 3.11 via mise (fallback: python3.11 binary)
  $SCRIPT_NAME python 3.12.2    # Use specific Python version via mise

Notes:
  - For Python: Uses mise exec, falls back to pythonX.Y binary in PATH
  - For Node: Use \`mise use node@<version>\` directly

Supported types: $SUPPORTED_TYPES
EOF
}

# Main function
main() {
    # Check if at least one argument is provided
    if [[ $# -lt 1 ]]; then
        echo "Error: Missing required argument" >&2
        echo "" >&2
        show_usage >&2
        exit 1
    fi

    # Handle help flag
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        show_usage
        exit 0
    fi

    # Determine the type of virtual environment to create
    case "$1" in
        envrc)
            deploy_envrc
            ;;
        python|py)
            create_python_env "${@:2}"
            ;;
        *)
            echo "Error: Unsupported environment type: $1" >&2
            echo "Supported types: $SUPPORTED_TYPES" >&2
            echo "" >&2
            show_usage >&2
            exit 1
            ;;
    esac
}

# Call the main function with all script arguments
main "$@"
