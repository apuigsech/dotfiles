#!/bin/bash

set -euo pipefail

# Constants
readonly SCRIPT_NAME="$(basename "$0")"
readonly SUPPORTED_TYPES="python, node"

# Get default Node version, with error handling
get_node_default_version() {
    if command -v nodeenv >/dev/null 2>&1; then
        nodeenv --list 2>/dev/null | tail -n 1 | awk '{print $NF}' || echo "latest"
    else
        echo "latest"
    fi
}

# Get default Python version
get_python_default_version() {
    python3 --version 2>/dev/null | awk '{print $2}' || echo "3"
}

readonly NODE_DEFAULT_VERSION=$(get_node_default_version)
readonly PYTHON_DEFAULT_VERSION=$(get_python_default_version)

# Function to deploy .envrc file
deploy_envrc() {
    local envrc_source="${DOTFILES_DIR}/plugins/direnv/.envrc"
    local envrc_target=".envrc"

    if [[ -z "${DOTFILES_DIR:-}" ]]; then
        echo "Error: DOTFILES_DIR environment variable is not set" >&2
        exit 1
    fi

    if [[ ! -f "$envrc_source" ]]; then
        echo "Error: Source .envrc file not found at $envrc_source" >&2
        exit 1
    fi

    if [[ -e "$envrc_target" ]]; then
        echo "Warning: .envrc already exists, removing it first" >&2
        rm -f "$envrc_target"
    fi

    ln -s "$envrc_source" "$envrc_target"
    echo ".envrc deployed successfully"
}

# Function to create a Python virtual environment
create_python_env() {
    local version="${1:-}"
    local python_cmd="python3"

    # If version is specified, try to find the appropriate Python binary
    if [[ -n "$version" ]]; then
        # Try pyenv first if available
        if command -v pyenv >/dev/null 2>&1; then
            if pyenv versions --bare | grep -q "^${version}"; then
                python_cmd="$(pyenv root)/versions/${version}/bin/python"
                echo "Using Python ${version} from pyenv"
            else
                echo "Error: Python ${version} not found in pyenv" >&2
                echo "Available versions:" >&2
                pyenv versions --bare >&2
                exit 1
            fi
        else
            # Try to find python binary with specific version
            local version_cmd="python${version}"
            if command -v "$version_cmd" >/dev/null 2>&1; then
                python_cmd="$version_cmd"
                echo "Using ${version_cmd}"
            else
                echo "Error: ${version_cmd} not found in PATH and pyenv is not installed" >&2
                echo "Available Python versions:" >&2
                ls -1 /usr/bin/python* 2>/dev/null || echo "  None found" >&2
                exit 1
            fi
        fi
    else
        echo "Using default Python version: $PYTHON_DEFAULT_VERSION"
    fi

    if ! command -v "$python_cmd" >/dev/null 2>&1 && [[ ! -x "$python_cmd" ]]; then
        echo "Error: $python_cmd is not installed or not in PATH" >&2
        exit 1
    fi

    if [[ -d ".venv" ]]; then
        echo "Warning: .venv directory already exists, removing it first" >&2
        rm -rf ".venv"
    fi

    echo "Creating Python virtual environment..."
    "$python_cmd" -m venv .venv
    deploy_envrc
    echo "Python virtual environment created successfully"
}

# Function to create a Node virtual environment
create_node_env() {
    local version="${1:-$NODE_DEFAULT_VERSION}"

    echo "Creating Node virtual environment with version: $version"

    if ! command -v nodeenv >/dev/null 2>&1; then
        echo "Error: nodeenv is not installed or not in PATH" >&2
        echo "Install it with: pip install nodeenv" >&2
        exit 1
    fi

    if [[ -d ".venv" ]]; then
        echo "Warning: .venv directory already exists, removing it first" >&2
        rm -rf ".venv"
    fi

    nodeenv .venv --node="$version" --force
    deploy_envrc
    echo "Node virtual environment created successfully"
}

# Function to display usage information
show_usage() {
    cat << EOF
Usage: $SCRIPT_NAME <type> [version]

Create a virtual environment with direnv integration.

Types:
  python, py    Create a Python virtual environment [version]
  node          Create a Node.js virtual environment [version]

Options:
  version       Python/Node.js version to use
                Python default: $PYTHON_DEFAULT_VERSION
                Node default: $NODE_DEFAULT_VERSION

Examples:
  $SCRIPT_NAME python           # Use default Python ($PYTHON_DEFAULT_VERSION)
  $SCRIPT_NAME python 3.11      # Use Python 3.11 (pyenv or python3.11 binary)
  $SCRIPT_NAME python 3.12.2    # Use specific Python version from pyenv
  $SCRIPT_NAME node             # Use default Node ($NODE_DEFAULT_VERSION)
  $SCRIPT_NAME node 18.17.0     # Use Node 18.17.0

Notes:
  - For Python: Tries pyenv first, falls back to pythonX.Y binary in PATH
  - For Node: Requires nodeenv to be installed (pip install nodeenv)

Supported types: $SUPPORTED_TYPES
EOF
}

# Main function
main() {
    # Check if at least one argument is provided
    if [[ $# -lt 1 ]]; then
        echo "Error: Missing required argument" >&2
        echo "" >&2
        show_usage >&2
        exit 1
    fi

    # Handle help flag
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        show_usage
        exit 0
    fi

    # Determine the type of virtual environment to create
    case "$1" in
        python|py)
            create_python_env "${@:2}"
            ;;
        node)
            create_node_env "${@:2}"
            ;;
        *)
            echo "Error: Unsupported environment type: $1" >&2
            echo "Supported types: $SUPPORTED_TYPES" >&2
            echo "" >&2
            show_usage >&2
            exit 1
            ;;
    esac
}

# Call the main function with all script arguments
main "$@"
