#!/bin/bash
# Usage: aws-op-credentials <item-name> <op-account>
# Outputs AWS credential_process compatible JSON from 1Password

ITEM="$1"
ACCOUNT="$2"

if [[ -z "$ITEM" || -z "$ACCOUNT" ]]; then
    echo "Usage: aws-op-credentials <item-name> <op-account>" >&2
    exit 1
fi

ACCESS_KEY=$(op item get "$ITEM" --account "$ACCOUNT" --fields label=access_key_id 2>/dev/null)
SECRET_KEY=$(op item get "$ITEM" --account "$ACCOUNT" --fields label=secret_access_key 2>/dev/null)

if [[ -z "$ACCESS_KEY" || -z "$SECRET_KEY" ]]; then
    echo "Error: could not retrieve credentials for '$ITEM' from 1Password" >&2
    exit 1
fi

printf '{"Version":1,"AccessKeyId":"%s","SecretAccessKey":"%s"}\n' "$ACCESS_KEY" "$SECRET_KEY"
