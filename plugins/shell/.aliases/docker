has_docker=$(command -v docker 2>/dev/null)
[[ -z $has_docker ]] && unset has_docker

if [[ -n $has_docker ]]; then
    alias d='docker'
    alias dc='docker compose'
    alias dps='docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"'
    alias dlog='docker logs -f'
    alias dex='docker exec -it'
    alias dprune='docker system prune -af'

    open-webui-start() {
        docker run -d -p 8080:8080 \
            --add-host=host.docker.internal:host-gateway \
            --name open-webui \
            --restart unless-stopped \
            ghcr.io/open-webui/open-webui:main
    }
    alias open-webui-stop='docker stop open-webui && docker rm open-webui'
    alias open-webui-update='open-webui-stop; docker pull ghcr.io/open-webui/open-webui:main && open-webui-start'
fi
