{
  "awsAuthRefresh": "aws sso login --profile claude",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_PROFILE": "claude",
    "AWS_REGION": "eu-west-1",
    "GITHUB_PERSONAL_ACCESS_TOKEN": "op://Private/GitHub/token"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\033]1337;SetProfile=claude\\a' > /dev/tty 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "echo $(op read --account MSUA4CBFK5ABDN2WY4Q64LCPJI \"op://Private/GitHub/token\") | /opt/homebrew/bin/gh auth login --with-token 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "github@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ontopix-plugins": {
      "source": {
        "source": "directory",
        "path": "/Users/apuigsech/Develop/github.com/ontopix/claude-setup"
      }
    },
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    }
  },
  "effortLevel": "low",
  "skipDangerousModePermissionPrompt": true,
  "model": "opus"
}
